{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DevflowRun": {
      "properties": {
        "agentId": {
          "type": "string"
        },
        "artifactIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "commandIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "completedAt": {
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "exitReason": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "input": {
          "type": "string"
        },
        "startedAt": {
          "format": "int64",
          "type": "integer"
        },
        "status": {
          "$ref": "#/definitions/DevflowRunStatus"
        },
        "streamSummary": {
          "type": [
            "string",
            "null"
          ]
        },
        "taskId": {
          "type": "string"
        },
        "threadId": {
          "type": [
            "string",
            "null"
          ]
        },
        "turnId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "agentId",
        "artifactIds",
        "commandIds",
        "id",
        "input",
        "startedAt",
        "status",
        "taskId"
      ],
      "type": "object"
    },
    "DevflowRunStatus": {
      "enum": [
        "queued",
        "running",
        "cancelled",
        "ready_for_review",
        "ready_to_merge",
        "failed"
      ],
      "type": "string"
    }
  },
  "properties": {
    "projectId": {
      "type": "string"
    },
    "run": {
      "$ref": "#/definitions/DevflowRun"
    },
    "taskId": {
      "type": "string"
    }
  },
  "required": [
    "projectId",
    "run",
    "taskId"
  ],
  "title": "DevflowRunStatusChangedNotification",
  "type": "object"
}