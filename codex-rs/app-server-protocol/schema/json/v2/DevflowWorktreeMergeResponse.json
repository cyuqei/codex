{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DevflowTask": {
      "properties": {
        "artifactIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "assignedAgentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "contextPackId": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/DevflowTaskKind"
        },
        "objective": {
          "type": "string"
        },
        "projectId": {
          "type": "string"
        },
        "riskLevel": {
          "$ref": "#/definitions/DevflowTaskRiskLevel"
        },
        "runIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "$ref": "#/definitions/DevflowTaskStatus"
        },
        "title": {
          "type": "string"
        },
        "triggerSource": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        },
        "worktreeId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "artifactIds",
        "createdAt",
        "dependencies",
        "id",
        "kind",
        "objective",
        "projectId",
        "riskLevel",
        "runIds",
        "status",
        "title",
        "updatedAt"
      ],
      "type": "object"
    },
    "DevflowTaskKind": {
      "enum": [
        "implementation",
        "review",
        "report",
        "diagnostic",
        "automation"
      ],
      "type": "string"
    },
    "DevflowTaskRiskLevel": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "DevflowTaskStatus": {
      "enum": [
        "planned",
        "running",
        "paused",
        "ready_for_review",
        "ready_to_merge",
        "failed",
        "blocked",
        "cancelled"
      ],
      "type": "string"
    },
    "DevflowWorktree": {
      "properties": {
        "baseBranch": {
          "type": [
            "string",
            "null"
          ]
        },
        "baseCommit": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "cwdPath": {
          "type": "string"
        },
        "headCommit": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "managed": {
          "type": "boolean"
        },
        "projectId": {
          "type": "string"
        },
        "repoRoot": {
          "type": "string"
        },
        "rootPath": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/DevflowWorktreeStatus"
        },
        "taskId": {
          "type": "string"
        },
        "updatedAt": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "baseCommit",
        "branch",
        "createdAt",
        "cwdPath",
        "id",
        "managed",
        "projectId",
        "repoRoot",
        "rootPath",
        "status",
        "taskId",
        "updatedAt"
      ],
      "type": "object"
    },
    "DevflowWorktreeStatus": {
      "enum": [
        "active",
        "dirty",
        "cleaned",
        "missing"
      ],
      "type": "string"
    }
  },
  "properties": {
    "conflicts": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "merged": {
      "type": "boolean"
    },
    "task": {
      "$ref": "#/definitions/DevflowTask"
    },
    "worktree": {
      "$ref": "#/definitions/DevflowWorktree"
    }
  },
  "required": [
    "conflicts",
    "merged",
    "task",
    "worktree"
  ],
  "title": "DevflowWorktreeMergeResponse",
  "type": "object"
}