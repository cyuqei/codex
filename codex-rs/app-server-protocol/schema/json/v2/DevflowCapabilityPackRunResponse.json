{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DevflowArtifact": {
      "properties": {
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/DevflowArtifactKind"
        },
        "mimeType": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "createdAt",
        "id",
        "kind",
        "mimeType",
        "path",
        "runId",
        "summary",
        "taskId",
        "title"
      ],
      "type": "object"
    },
    "DevflowArtifactKind": {
      "enum": [
        "context_pack",
        "diff",
        "delivery_receipt",
        "output_archive",
        "quality_gate_output",
        "report",
        "review_report",
        "run_summary"
      ],
      "type": "string"
    },
    "DevflowCapabilityPack": {
      "properties": {
        "capabilities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "diagnostics": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sourcePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/DevflowPackStatus"
        }
      },
      "required": [
        "capabilities",
        "diagnostics",
        "id",
        "name",
        "status"
      ],
      "type": "object"
    },
    "DevflowCapabilityPackRunStatus": {
      "enum": [
        "completed",
        "failed",
        "skipped"
      ],
      "type": "string"
    },
    "DevflowPackStatus": {
      "enum": [
        "available",
        "missing",
        "disabled"
      ],
      "type": "string"
    }
  },
  "properties": {
    "artifact": {
      "anyOf": [
        {
          "$ref": "#/definitions/DevflowArtifact"
        },
        {
          "type": "null"
        }
      ]
    },
    "pack": {
      "$ref": "#/definitions/DevflowCapabilityPack"
    },
    "status": {
      "$ref": "#/definitions/DevflowCapabilityPackRunStatus"
    },
    "summary": {
      "type": "string"
    }
  },
  "required": [
    "pack",
    "status",
    "summary"
  ],
  "title": "DevflowCapabilityPackRunResponse",
  "type": "object"
}