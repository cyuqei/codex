{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DevflowArtifact": {
      "properties": {
        "createdAt": {
          "format": "int64",
          "type": "integer"
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/DevflowArtifactKind"
        },
        "mimeType": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "createdAt",
        "id",
        "kind",
        "mimeType",
        "path",
        "runId",
        "summary",
        "taskId",
        "title"
      ],
      "type": "object"
    },
    "DevflowArtifactKind": {
      "enum": [
        "context_pack",
        "diff",
        "delivery_receipt",
        "output_archive",
        "quality_gate_output",
        "report",
        "review_report",
        "run_summary"
      ],
      "type": "string"
    },
    "DevflowPackStatus": {
      "enum": [
        "available",
        "missing",
        "disabled"
      ],
      "type": "string"
    },
    "DevflowPolicyPack": {
      "properties": {
        "appliesToRiskLevels": {
          "items": {
            "$ref": "#/definitions/DevflowTaskRiskLevel"
          },
          "type": "array"
        },
        "diagnostics": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "policies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "sourcePath": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/DevflowPackStatus"
        }
      },
      "required": [
        "appliesToRiskLevels",
        "diagnostics",
        "id",
        "name",
        "policies",
        "status"
      ],
      "type": "object"
    },
    "DevflowTaskRiskLevel": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    }
  },
  "properties": {
    "applied": {
      "type": "boolean"
    },
    "artifact": {
      "anyOf": [
        {
          "$ref": "#/definitions/DevflowArtifact"
        },
        {
          "type": "null"
        }
      ]
    },
    "diagnostics": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "pack": {
      "$ref": "#/definitions/DevflowPolicyPack"
    },
    "requiredArtifacts": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "applied",
    "diagnostics",
    "pack",
    "requiredArtifacts"
  ],
  "title": "DevflowPolicyPackApplyResponse",
  "type": "object"
}